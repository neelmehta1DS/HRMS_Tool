# Slack LeaveBot configuration — copy to `.env` and fill in real values.
# Never commit the real `.env`; it is gitignored.

# Bot token (xoxb-...) from the Slack app's OAuth & Permissions page.
SLACK_BOT_TOKEN=xoxb-...

# App-level token (xapp-...) with connections:write, for Socket Mode.
SLACK_APP_TOKEN=xapp-...

# Base URL of the HRMS backend the bot calls (/bot/* endpoints).
BACKEND_URL=http://localhost:8000

# Shared secret sent as `x-internal-key`. Must match INTERNAL_API_KEY in the
# backend's .env.
INTERNAL_API_KEY=change-me

# Demo mode redirects every DM to DEMO_USER_ID so one person can test the whole
# flow. Set to false in production.
DEMO_MODE=false
DEMO_USER_ID=
