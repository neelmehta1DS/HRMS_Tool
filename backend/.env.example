# Backend configuration — copy to `.env` and fill in real values.
# Never commit the real `.env`; it is gitignored.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is fine for local dev. Use a Postgres URL in production, e.g.
# postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./database.db

# ── App ───────────────────────────────────────────────────────────────────────
# Enables dev-only behaviour (seed data, /auth/dev-login, insecure OAuth
# transport). MUST be False in production.
DEBUG=False

# Public base URL of the backend. Used to build the Google OAuth redirect URI,
# so it must exactly match an authorised redirect URI in the Google console.
APP_BASE_URL=http://localhost:8000

# Where users are redirected after a successful Google login (the frontend URL).
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed CORS origins (the frontend's URL(s)).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Secret used to sign JWTs and session cookies. Generate a strong random value,
# e.g. `python -c "import secrets; print(secrets.token_hex(32))"`.
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Google OAuth (Sign-in + Calendar/Drive for catchups) ──────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Slack integration ─────────────────────────────────────────────────────────
# Shared secret the Slack bot sends as `x-internal-key` on /bot/* calls. Must
# match INTERNAL_API_KEY in the slack_myleave service.
INTERNAL_API_KEY=change-me

# Bot token (xoxb-...) used by the backend to post/DELETE Slack messages.
SLACK_BOT_TOKEN=

# Demo mode redirects every Slack DM to SLACK_DEMO_USER_ID so one person can test
# the whole flow. Leave off in production.
SLACK_DEMO_MODE=False
SLACK_DEMO_USER_ID=

# Channel ID for the daily morning digest. Leave blank to disable it.
SLACK_DIGEST_CHANNEL=
