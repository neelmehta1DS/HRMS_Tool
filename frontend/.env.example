# Frontend configuration — copy to `.env.local` and adjust as needed.
# Vite only exposes variables prefixed with VITE_. These are baked into the
# bundle at build time, so set them before running `npm run build` in production.

# Base URL of the HRMS backend. Falls back to http://localhost:8000 when unset.
VITE_API_URL=http://localhost:8000
